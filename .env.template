# ══════════════════════════════════════════════════════════════════════
# PAS-SCADA-Kafka-Bridge — Environment Variables Template
#
# All values below are the WORKING LOCAL/MINIKUBE DEFAULTS that match
# what start.sh uses when no env vars are set. Copy this file, then
# change ONLY the values that differ for your environment.
#
# Usage:
#   cp .env.template /home/ops/.env.prod
#   chmod 600 /home/ops/.env.prod
#   nano /home/ops/.env.prod         # change values for prod
#   source /home/ops/.env.prod
#   ./start.sh
#
# NEVER commit .env, .env.prod, or .env.local — they're in .gitignore.
# Generate AES key with:  openssl rand -base64 32
# ══════════════════════════════════════════════════════════════════════

# ── Mode flag for start.sh ────────────────────────────────────────────
# 1 = client's Artemis runs on a remote host; skip the local docker compose.
# 0 = local Artemis from $MESSAGING_INFRA via docker compose (dev default).
SKIP_ARTEMIS=0

# ── Spring Profile (used by docker-compose deploy path) ───────────────
SPRING_PROFILES_ACTIVE=prod

# ══════════════════════════════════════════════════════════════════════
#  ActiveMQ Artemis (TMS-side broker)
# ══════════════════════════════════════════════════════════════════════
# DEV (host Docker via messaging-infra):
ARTEMIS_BROKER_URL=tcp://host.minikube.internal:61616
ARTEMIS_HOST=host.minikube.internal
ARTEMIS_PORT=61616
ARTEMIS_USER=pasbridge
ARTEMIS_PASSWORD=testpass123
ARTEMIS_PASS=testpass123

# PROD overrides (uncomment + replace when on cloud server):
# SKIP_ARTEMIS=1
# ARTEMIS_BROKER_URL=tcp://10.4.0.23:61616
# ARTEMIS_HOST=10.4.0.23
# ARTEMIS_PORT=61616
# ARTEMIS_USER=<client-given-username>
# ARTEMIS_PASSWORD=<client-given-password>

# ══════════════════════════════════════════════════════════════════════
#  Apache Kafka (in-cluster)
# ══════════════════════════════════════════════════════════════════════
KAFKA_HOST=kafka-service.pinkline.svc.cluster.local
KAFKA_PORT=9092
# For external Kafka with SASL_SSL (uncomment in prod):
# KAFKA_USER=tms_bridge
# KAFKA_PASS=changeme

# ══════════════════════════════════════════════════════════════════════
#  RabbitMQ (SCADA-side, AMQP)
# ══════════════════════════════════════════════════════════════════════
# DEV (in-cluster scada namespace):
RABBITMQ_HOST=rabbitmq-internal.scada.svc.cluster.local
RABBITMQ_PORT=5672
RABBITMQ_USER=thiru
RABBITMQ_PASS=password

# PROD overrides (uncomment when RabbitMQ is on a separate VM):
# RABBITMQ_HOST=10.4.0.25
# RABBITMQ_PORT=5673
# RABBITMQ_USER=<your-rabbitmq-user>
# RABBITMQ_PASS=<your-rabbitmq-password>

# ══════════════════════════════════════════════════════════════════════
#  MQTT (RabbitMQ MQTT plugin — same broker, different port)
# ══════════════════════════════════════════════════════════════════════
MQTT_HOST=rabbitmq-internal.scada.svc.cluster.local
MQTT_PORT=1883
MQTT_USER=thiru
MQTT_PASS=password

# PROD overrides (uncomment when on cloud server):
# MQTT_HOST=10.4.0.25
# MQTT_PORT=1884
# MQTT_USER=<your-mqtt-user>
# MQTT_PASS=<your-mqtt-password>

# ══════════════════════════════════════════════════════════════════════
#  Encryption — AES-256-GCM
# ══════════════════════════════════════════════════════════════════════
# Base64 of 32 random bytes. MUST match between bridge and scada-api
# (start.sh keeps them in sync automatically when this single env var is set).
# Generate fresh key with:  openssl rand -base64 32
SCADA_AES_KEY=k7Qh2NfT8vR0mC9aXy4pLwZbE3sG6uJtH1iKd5oArMw=

# PROD: rotate the key (uncomment + paste output of openssl rand -base64 32):
# SCADA_AES_KEY=<base64-encoded-32-byte-key>

# ══════════════════════════════════════════════════════════════════════
#  Bridge mode toggles
# ══════════════════════════════════════════════════════════════════════
# Mode B (Connect-driven) — recommended; matches the live config.
BRIDGE_INPUT_FROM_KAFKA=true
BRIDGE_REVERSE_KAFKA_ENABLED=true
BRIDGE_REVERSE_KAFKA_ENCRYPT_ENABLED=false

# In Mode B keep this as "kafka" — Connect handles RabbitMQ + MQTT delivery.
# In Mode A use "kafka,rabbitmq,mqtt" for full chain via Camel.
BRIDGE_PIPELINE=kafka

# ── SCADA Creator ID (informational; matches the SCADA simulator) ─────
SCADA_CREATOR_ID=ScateX

# ── TLS (optional — uncomment when truststore is mounted via Secret) ──
# TLS_TRUSTSTORE_PATH=/opt/pinkline/certs/truststore.jks
# TLS_TRUSTSTORE_PASS=changeme

# ── In-bridge monitor route (optional, default off) ───────────────────
BRIDGE_MONITOR_ENABLED=false
BRIDGE_MONITOR_FROM_EXCHANGE=amq.topic
BRIDGE_MONITOR_ROUTING_KEY=tms.scada.pas
BRIDGE_MONITOR_QUEUE=scada.monitor.queue
